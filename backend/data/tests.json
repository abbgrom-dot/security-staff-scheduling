{
  "tests": [
    {
      "name": "Load all data",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"holding": {"id": 1}},
      "bodyMatcher": "partial"
    },
    {
      "name": "Add post as superadmin",
      "method": "POST",
      "path": "/",
      "headers": {"X-User-Id": "1"},
      "body": {"entity": "post", "action": "add", "data": {"orgId": 1, "name": "Тестовый пост", "locationId": 1, "time": "08:00 – 20:00", "status": "vacant"}},
      "expectedStatus": 200,
      "expectedBody": {"item": {"name": "Тестовый пост"}},
      "bodyMatcher": "partial"
    },
    {
      "name": "Add post without user forbidden",
      "method": "POST",
      "path": "/",
      "body": {"entity": "post", "action": "add", "data": {"orgId": 1, "name": "Без прав", "locationId": 1, "time": "08:00 – 20:00", "status": "vacant"}},
      "expectedStatus": 403
    },
    {
      "name": "Cannot delete self",
      "method": "POST",
      "path": "/",
      "headers": {"X-User-Id": "1"},
      "body": {"entity": "user", "action": "delete", "data": {"id": 1}},
      "expectedStatus": 403
    },
    {
      "name": "Set schedule entry as superadmin",
      "method": "POST",
      "path": "/",
      "headers": {"X-User-Id": "1"},
      "body": {"entity": "schedule", "action": "set", "data": {"orgId": 1, "employeeId": 1, "date": "2026-07-20", "kind": "day", "locationId": 1, "postId": 1, "shift": "08:00 – 20:00"}},
      "expectedStatus": 200,
      "expectedBody": {"item": {"employeeId": 1, "kind": "day"}},
      "bodyMatcher": "partial"
    },
    {
      "name": "Set schedule without user forbidden",
      "method": "POST",
      "path": "/",
      "body": {"entity": "schedule", "action": "set", "data": {"orgId": 1, "employeeId": 1, "date": "2026-07-21", "kind": "off"}},
      "expectedStatus": 403
    },
    {
      "name": "Unknown entity error",
      "method": "POST",
      "path": "/",
      "headers": {"X-User-Id": "1"},
      "body": {"entity": "nope", "action": "add", "data": {}},
      "expectedStatus": 400
    }
  ]
}